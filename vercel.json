{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "server/src/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "server/src/index.js"
    },
    {
      "source": "/uploads/:match*",
      "destination": "server/src/index.js"
    },
    {
      "source": "/((?!api|uploads).*)",
      "destination": "client/$1"
    }
  ]
}
