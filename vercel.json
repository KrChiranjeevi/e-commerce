{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "https://e-commerce-amrn.onrender.com/api/:match*"
    },
    {
      "source": "/uploads/:match*",
      "destination": "https://e-commerce-amrn.onrender.com/uploads/:match*"
    },
    {
      "source": "/((?!api|uploads).*)",
      "destination": "client/$1"
    }
  ]
}
